<Window x:Class="CsvViewer.ConfirmSaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Módosítások áttekintése" Height="520" Width="1300"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">

    <DockPanel>
        <!-- Top bar -->
        <Border DockPanel.Dock="Top" Background="#ECEFF1" Padding="7,6"
                BorderBrush="#CFD8DC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Click="BtnConfirm_Click" Padding="16,7" Margin="0,0,6,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold">
                    Mentés
                </Button>
                <Button Click="BtnCancel_Click" Padding="16,7" Margin="0,0,16,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold">
                    Mégse
                </Button>
                <TextBlock x:Name="txtSummary" VerticalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold" Foreground="#37474F"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#ECEFF1">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Margin="4,0"
                           FontWeight="SemiBold" Foreground="#1A237E" FontSize="13"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Changes grid -->
        <DataGrid x:Name="changesGrid"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#E0E0E0"
                  VerticalGridLinesBrush="#CFD8DC"
                  HeadersVisibility="Column"
                  ColumnHeaderHeight="30"
                  RowHeight="22"
                  FontSize="12"
                  FontWeight="Bold">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Muvelet}" Value="Törlés">
                            <Setter Property="Background" Value="#FFCDD2"/>
                            <Setter Property="Foreground" Value="#B71C1C"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Muvelet}" Value="Módosítás">
                            <Setter Property="Background" Value="#FFF9C4"/>
                            <Setter Property="Foreground" Value="#E65100"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Művelet"      Binding="{Binding Muvelet}"  Width="90"/>
                <DataGridTextColumn Header="Lemez"        Binding="{Binding Disc}"     Width="65"/>
                <DataGridTextColumn Header="Track"        Binding="{Binding Track}"    Width="55"/>
                <DataGridTextColumn Header="Előadó neve"  Binding="{Binding Artist}"   Width="180"/>
                <DataGridTextColumn Header="Zeneszám cím" Binding="{Binding Title}"    Width="200"/>
                <DataGridTextColumn Header="Hossz"        Binding="{Binding Duration}" Width="65"/>
                <DataGridTextColumn Header="Stílus"       Binding="{Binding Info}"     Width="110"/>
                <DataGridTextColumn Header="Kiadó"        Binding="{Binding Album}"    Width="130"/>
                <DataGridTextColumn Header="CD Cím"       Binding="{Binding CdCim}"    Width="180"/>
                <DataGridTextColumn Header="Beérk."       Binding="{Binding BeerkDat}" Width="90"/>
                <DataGridTextColumn Header="Lej. d."      Binding="{Binding LejDat}"   Width="90"/>
                <DataGridTextColumn Header="Lej. i."      Binding="{Binding LejIdo}"   Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
