<Window x:Class="CsvViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CSV Néző" Height="750" Width="1200"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- ── Fejléc sáv ───────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#ECEFF1" Padding="8,6"
                BorderBrush="#CFD8DC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Adatbázis:" VerticalAlignment="Center"
                           FontSize="13" FontWeight="SemiBold" Foreground="#37474F"
                           Margin="0,0,7,0"/>
                <ComboBox x:Name="dbSelector" MinWidth="260" Height="30" FontSize="13"
                          VerticalContentAlignment="Center" Margin="0,0,8,0"
                          SelectionChanged="DbSelector_Changed"/>
                <Button Click="BtnOpen_Click" Padding="12,6" FontWeight="SemiBold"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontSize="13" Margin="0,0,5,0">
                    Adatbázis (db)
                </Button>
                <Button Click="BtnCloseDb_Click" Padding="12,6"
                        Background="#B71C1C" Foreground="White" BorderThickness="0"
                        FontSize="13">
                    Bezárás
                </Button>
            </StackPanel>
        </Border>

        <!-- ── Aktív nézet ──────────────────────────────────────────────── -->
        <ContentControl x:Name="contentArea"/>
    </DockPanel>
</Window>
