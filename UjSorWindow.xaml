<Window x:Class="CsvViewer.UjSorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        Height="750" Width="1400"
        WindowState="Maximized">

    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#37474F"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="BorderBrush" Value="#546E7A"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#BBDEFB"/>
                    <Setter Property="Foreground" Value="#000000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- ── Felső panel ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Background="#ECEFF1" Padding="7,6"
                BorderBrush="#CFD8DC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <Button x:Name="btnSave" Click="BtnSave_Click" Padding="12,7" Margin="0,0,5,0"
                        Background="#2E7D32" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                    Mentés
                </Button>

                <Button Click="BtnClose_Click" Padding="12,7" Margin="0,0,8,0"
                        Background="#546E7A" Foreground="White" BorderThickness="0"
                        FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                    Bezárás
                </Button>

                <Button Click="BtnHelp_Click"
                        Width="34" Height="34"
                        Background="#1565C0" Foreground="White" BorderThickness="0"
                        FontSize="18" FontWeight="Bold"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        ToolTip="Súgó / Kézikönyv megnyitása">
                    ?
                </Button>

            </StackPanel>
        </Border>

        <!-- ── Állapotsor ────────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Background="#ECEFF1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Margin="4,0"
                           FontWeight="SemiBold" Foreground="#1A237E" FontSize="13"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── DataGrid ──────────────────────────────────────────────────────── -->
        <DataGrid x:Name="dataGrid"
                  ItemsSource="{Binding RowsView}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  CanUserAddRows="False"
                  SelectionUnit="Cell"
                  SelectionMode="Single"
                  IsReadOnly="False"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#E0E0E0"
                  VerticalGridLinesBrush="#CFD8DC"
                  AlternatingRowBackground="#F0F4F8"
                  RowBackground="#FEFCF8"
                  HeadersVisibility="Column"
                  ColumnHeaderHeight="30"
                  RowHeight="22"
                  FontSize="12"
                  FontWeight="Bold"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.VerticalScrollBarVisibility="Visible">

            <DataGrid.Columns>

                <!-- 0 · Törlés -->
                <DataGridTemplateColumn Header="⌫" Width="34"
                                        CanUserReorder="False" CanUserResize="False" IsReadOnly="True">
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕" Click="DeleteRow_Click" ClickMode="Press"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#B71C1C" FontSize="13" FontWeight="Bold"
                                    Cursor="Hand"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Padding="0" ToolTip="Sor törlése"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Lemez sorszám"
                                    Binding="{Binding Disc, UpdateSourceTrigger=PropertyChanged}"     Width="120"/>
                <DataGridTextColumn Header="Track"
                                    Binding="{Binding Track, UpdateSourceTrigger=PropertyChanged}"    Width="62"/>
                <DataGridTextColumn Header="Előadó neve"
                                    Binding="{Binding Artist, UpdateSourceTrigger=PropertyChanged}"   Width="190"/>
                <DataGridTextColumn Header="Zeneszám címe"
                                    Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}"    Width="200"/>
                <DataGridTextColumn Header="Hossz"
                                    Binding="{Binding Duration, UpdateSourceTrigger=PropertyChanged}" Width="78"/>
                <DataGridTextColumn Header="Stílus"
                                    Binding="{Binding Info, UpdateSourceTrigger=PropertyChanged}"     Width="120"/>
                <DataGridTextColumn Header="Kiadó"
                                    Binding="{Binding Album, UpdateSourceTrigger=PropertyChanged}"    Width="150"/>
                <DataGridTextColumn Header="CD Cím"
                                    Binding="{Binding CdCim, UpdateSourceTrigger=PropertyChanged}"    Width="190"/>
                <DataGridTextColumn Header="Beérk. dátum"
                                    Binding="{Binding BeerkDat, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="Lej. dátum"
                                    Binding="{Binding LejDat, UpdateSourceTrigger=PropertyChanged}"   Width="110"/>
                <DataGridTextColumn Header="Lej. idő"
                                    Binding="{Binding LejIdo, UpdateSourceTrigger=PropertyChanged}"   Width="90"/>

            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>

    <!-- Save overlay -->
    <Border x:Name="saveOverlay" Visibility="Collapsed"
            Background="#CC1A237E" IsHitTestVisible="True">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Mentés folyamatban..." Foreground="White"
                       FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
            <TextBlock Text="Kérjük várjon..." Foreground="#BBDEFB"
                       FontSize="18" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>

    </Grid>
</Window>
